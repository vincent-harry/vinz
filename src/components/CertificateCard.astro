---
import type { Credential } from "../data/certificates";

interface Props {
  credential: Credential;
}

const { credential } = Astro.props;
---

<article class="credential-card">
  {credential.image && (
    <button
      class="credential-image"
      type="button"
      data-lightbox={credential.image}
      data-lightbox-title={credential.title}
      aria-label={`View ${credential.title} certificate`}
    >
      <img src={credential.image} alt={`${credential.title} certificate issued to Vincent Harry H. Trayvilla`} loading="lazy" />
    </button>
  )}
  <div class="credential-content">
    <p class="credential-type">{credential.category} | {credential.date}</p>
    <h3>{credential.title}</h3>
    {credential.issuer && <p class="credential-issuer">{credential.issuer}</p>}
    <p>{credential.description}</p>
    {credential.file && (
      <div class="card-actions">
        {credential.image ? (
          <button
            class="btn btn-pale"
            type="button"
            data-lightbox-open={credential.image}
            aria-label={`View ${credential.title} in the certificate modal`}
          >
            View
          </button>
        ) : (
          <a
            class="btn btn-pale"
            href={credential.file}
            target="_blank"
            rel="noopener noreferrer"
            aria-label={`View ${credential.title} in a new tab`}
          >
            View
          </a>
        )}
        <a
          class="btn btn-warm"
          href={credential.file}
          target="_blank"
          rel="noopener noreferrer"
          download
          aria-label={`Download ${credential.title}`}
        >
          Download
        </a>
      </div>
    )}
  </div>
</article>
