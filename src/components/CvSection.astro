---
import SectionHeading from "./SectionHeading.astro";
import { cvData, cvPath } from "../data/cv";

const { personalInformation } = cvData;
---

<section class="section section-muted" id="cv" aria-labelledby="cv-heading">
  <div class="container">
    <SectionHeading
      id="cv-heading"
      eyebrow="Curriculum Vitae"
      title="Curriculum Vitae"
      intro="Professional and Academic Background"
    />

    <div class="cv-actions">
      <a
        class="btn btn-primary"
        href={cvPath}
        target="_blank"
        rel="noopener noreferrer"
        aria-label="View Vincent Harry Trayvilla's professional CV PDF in a new tab"
      >
        View CV
      </a>
      <a
        class="btn btn-pale"
        href={cvPath}
        target="_blank"
        rel="noopener noreferrer"
        download
        aria-label="Download Vincent Harry Trayvilla's professional CV PDF"
      >
        Download CV
      </a>
    </div>

    <article class="cv-document" aria-label="Responsive HTML curriculum vitae">
      <header class="cv-nameplate">
        <p class="cv-person-name">{personalInformation.name}</p>
        <p>{personalInformation.title}</p>
        <address class="cv-contact-block" aria-label="Contact information">
          <dl class="cv-contact-list">
            <div>
              <dt>Location</dt>
              <dd>{personalInformation.location}</dd>
            </div>
            <div>
              <dt>Phone</dt>
              <dd><a href={personalInformation.phone.href}>{personalInformation.phone.display}</a></dd>
            </div>
            <div>
              <dt>Email</dt>
              <dd><a href={personalInformation.email.href}>{personalInformation.email.display}</a></dd>
            </div>
            <div>
              <dt>LinkedIn</dt>
              <dd>
                <a
                  href={personalInformation.linkedin.href}
                  target="_blank"
                  rel="noopener noreferrer"
                >
                  {personalInformation.linkedin.display}
                </a>
              </dd>
            </div>
            <div>
              <dt>GitHub</dt>
              <dd>
                <a
                  href={personalInformation.github.href}
                  target="_blank"
                  rel="noopener noreferrer"
                >
                  {personalInformation.github.display}
                </a>
              </dd>
            </div>
            <div>
              <dt>Portfolio</dt>
              <dd>
                <a
                  href={personalInformation.portfolio.href}
                  target="_blank"
                  rel="noopener noreferrer"
                >
                  {personalInformation.portfolio.display}
                </a>
              </dd>
            </div>
          </dl>
        </address>
      </header>

      <section class="cv-section">
        <h3>Professional Summary</h3>
        <p>{cvData.professionalSummary}</p>
      </section>

      <section class="cv-section">
        <h3>Work Experience</h3>
        {
          cvData.workExperience.map((entry) => (
            <article class="cv-entry">
              <div class="cv-entry-heading">
                <div>
                  <h4>{entry.organization}</h4>
                  <p>{entry.location} | {entry.position}</p>
                </div>
                <p>{entry.dates}</p>
              </div>
              <p><strong>Assigned Project:</strong> {entry.assignedProject}</p>
              <ul class="plain-list">
                {entry.responsibilities.map((responsibility) => <li>{responsibility}</li>)}
              </ul>
            </article>
          ))
        }
      </section>

      <section class="cv-section">
        <h3>Projects</h3>
        {
          cvData.projects.map((project) => (
            <article class="cv-entry">
              <div class="cv-entry-heading">
                <div>
                  <h4>{project.title}</h4>
                  <p>{project.role}</p>
                </div>
                <p>{project.dates}</p>
              </div>
              <p><strong>Software Used:</strong> {project.softwareUsed}</p>
              <p>{project.description}</p>
            </article>
          ))
        }
      </section>

      <section class="cv-section">
        <h3>Education</h3>
        {
          cvData.education.map((entry) => (
            <article class="cv-entry education-entry">
              <div class="cv-entry-heading">
                <div>
                  <h4>{entry.school}</h4>
                  <p>{entry.location}</p>
                </div>
                <p>{entry.graduation}</p>
              </div>
              <p><strong>{entry.program}</strong></p>
              <p><strong>Academic Achievements:</strong> {entry.academicAchievements}</p>
              <p><strong>Relevant Coursework:</strong></p>
              <ul class="plain-list cv-coursework-list">
                {entry.relevantCoursework.map((course) => <li>{course}</li>)}
              </ul>
            </article>
          ))
        }
      </section>

      <section class="cv-section">
        <h3>Technical Skills</h3>
        <div class="cv-technical-grid">
          {
            cvData.technicalSkills.map((group) => (
              <div class="cv-skill-group">
                <h4>{group.category}</h4>
                <ul class="tag-list compact">
                  {group.skills.map((skill) => <li>{skill}</li>)}
                </ul>
              </div>
            ))
          }
        </div>
      </section>

      <section class="cv-section">
        <h3>Certifications</h3>
        <ul class="two-column-list cv-certification-list">
          {
            cvData.certifications.map((certification) => (
              <li>
                <span>{certification.title}</span>
                <strong>{certification.date}</strong>
              </li>
            ))
          }
        </ul>
      </section>

      <section class="cv-section">
        <h3>Student Organizations</h3>
        <ul class="cv-organization-list">
          {
            cvData.organizations.map((organization) => (
              <li>
                <strong>{organization.name}</strong>
                <span>{organization.school}</span>
                <span>{organization.role}</span>
              </li>
            ))
          }
        </ul>
      </section>
    </article>
  </div>
</section>
