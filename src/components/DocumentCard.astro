---
import type { AppendixDocument } from "../data/appendices";

interface Props {
  document: AppendixDocument;
}

const { document } = Astro.props;
---

<article class="document-card">
  <p class="document-number">Appendix {document.number}</p>
  <h3>{document.title}</h3>
  {document.subtitle && <p class="document-subtitle">{document.subtitle}</p>}
  <p>{document.description}</p>

  {
    document.file ? (
      <div class="card-actions">
        <a
          class="btn btn-primary"
          href={document.file}
          target="_blank"
          rel="noopener noreferrer"
          aria-label={`${document.viewLabel ?? "View PDF"} for Appendix ${document.number}: ${document.title} in a new tab`}
        >
          {document.viewLabel ?? "View PDF"}
        </a>
        <a
          class="btn btn-pale"
          href={document.file}
          target="_blank"
          rel="noopener noreferrer"
          download
          aria-label={`${document.downloadLabel ?? "Download"} for Appendix ${document.number}: ${document.title}`}
        >
          {document.downloadLabel ?? "Download"}
        </a>
      </div>
    ) : (
      <p class="document-unavailable">Source document not provided</p>
    )
  }
</article>
