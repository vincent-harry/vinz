---
const links = [
  { href: "#home", label: "Home" },
  { href: "#about", label: "About Me" },
  { href: "#cv", label: "Curriculum Vitae" },
  { href: "#skills", label: "Skills" },
  { href: "#certificates", label: "Certificates" },
  { href: "#seminars", label: "Seminars" },
  { href: "#projects", label: "Software Developed" },
  { href: "#capstone", label: "Capstone Project" },
  { href: "#practicum", label: "Final Output" },
  { href: "#appendices", label: "Appendices" },
  { href: "#contact", label: "Contact", cta: true },
];
---

<header class="site-header" data-site-header>
  <nav class="site-nav container-wide" aria-label="Primary navigation">
    <a class="brand" href="#home" aria-label="Vincent Trayvilla portfolio home">
      <span class="brand-mark" aria-hidden="true">VT</span>
      <span>Vincent Trayvilla</span>
    </a>

    <button
      class="nav-toggle"
      type="button"
      aria-expanded="false"
      aria-controls="primary-nav"
      aria-label="Open navigation"
    >
      <span aria-hidden="true"></span>
      <span aria-hidden="true"></span>
      <span aria-hidden="true"></span>
    </button>

    <ul class="nav-links" id="primary-nav">
      {
        links.map((link, index) => (
          <li>
            <a
              href={link.href}
              class:list={{ active: index === 0, "nav-contact": link.cta }}
              aria-current={index === 0 ? "location" : undefined}
              data-section-link
            >
              {link.label}
            </a>
          </li>
        ))
      }
    </ul>
  </nav>
</header>
