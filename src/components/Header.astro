---
const pathname = Astro.url.pathname;
const links = [
  { href: "/", label: "Home", path: "/" },
  { href: "/cv/", label: "Curriculum Vitae", path: "/cv/" },
  { href: "/#skills", label: "Skills", path: "/#skills" },
  { href: "/certificates/", label: "Certificates", path: "/certificates/" },
  { href: "/certificates/#seminars", label: "Seminars", path: "/certificates/" },
  { href: "/projects/", label: "Software Developed", path: "/projects/" },
  { href: "/capstone/", label: "Capstone Project", path: "/capstone/" },
];
---

<header class="site-header">
  <nav class="site-nav container-wide" aria-label="Primary navigation">
    <a class="brand" href="/" aria-label="Vincent Trayvilla portfolio home">
      <span class="brand-mark" aria-hidden="true">VT</span>
      <span>Vincent Trayvilla</span>
    </a>
    <button class="nav-toggle" type="button" aria-expanded="false" aria-controls="primary-nav">
      <span class="sr-only">Toggle navigation</span>
      <span></span><span></span><span></span>
    </button>
    <ul class="nav-links" id="primary-nav">
      {links.map((link) => {
        const active = link.href.includes("#")
          ? false
          : link.path === "/"
            ? pathname === "/"
            : pathname === link.path;
        return (
          <li><a href={link.href} class:list={{ active }} aria-current={active ? "page" : undefined}>{link.label}</a></li>
        );
      })}
      <li><a class="nav-contact" href="/#contact">Contact</a></li>
    </ul>
  </nav>
</header>
