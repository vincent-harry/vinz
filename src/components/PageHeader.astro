---
interface Props {
  eyebrow: string;
  title: string;
  intro: string;
}

const { eyebrow, title, intro } = Astro.props;
---

<header class="page-header">
  <div class="container reading-width">
    <p class="eyebrow">{eyebrow}</p>
    <h1>{title}</h1>
    <p class="page-intro">{intro}</p>
  </div>
</header>
