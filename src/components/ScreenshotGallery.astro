---
interface Image {
  src: string;
  alt: string;
  caption: string;
}

interface Props {
  images: Image[];
  label: string;
  group: string;
}

const { images, label, group } = Astro.props;
---

<div class="screenshot-grid" aria-label={label}>
  {images.map((image) => (
    <figure class="screenshot-card">
      <button
        class="gallery-button"
        type="button"
        data-lightbox={image.src}
        data-lightbox-title={image.caption}
        data-lightbox-group={group}
        aria-label={`View ${image.caption} full size`}
      >
        <img src={image.src} alt={image.alt} loading="lazy" decoding="async" />
      </button>
      <figcaption>{image.caption}</figcaption>
    </figure>
  ))}
</div>
