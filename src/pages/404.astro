---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
  title="Page Not Found | Vincent Trayvilla"
  description="The requested page could not be found in Vincent Trayvilla's portfolio."
  path="/404/"
>
  <section class="not-found">
    <div class="container reading-width">
      <p class="eyebrow">404</p>
      <h1>Page not found</h1>
      <p>The requested page is not part of this portfolio.</p>
      <a class="btn btn-primary" href="/">Return to Home</a>
    </div>
  </section>
</BaseLayout>
