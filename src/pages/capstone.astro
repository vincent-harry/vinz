---
import BaseLayout from "../layouts/BaseLayout.astro";
import PageHeader from "../components/PageHeader.astro";
import SectionHeading from "../components/SectionHeading.astro";
import ScreenshotGallery from "../components/ScreenshotGallery.astro";
import { capstone, capstoneImages } from "../data/capstone";

const guiImages = capstoneImages.filter((image) => image.group === "GUI Screenshots");
const hardwareImages = capstoneImages.filter((image) => image.group === "Hardware");
const testingImages = capstoneImages.filter((image) => image.group === "Testing");
---

<BaseLayout
  title="PlanterAid Capstone Project | Vincent Trayvilla"
  description="PlanterAid Capstone project overview, features, GUI screenshots, software, hardware, methodology, and testing materials."
  path="/capstone/"
>
  <PageHeader
    eyebrow="Fourth Year Capstone Project"
    title="PlanterAid"
    intro={capstone.title}
  />

  <article class="section capstone-article">
    <div class="container reading-width report-content">
      <section>
        <h2>Project Overview</h2>
        <p>{capstone.overview}</p>
      </section>
      <section>
        <h2>Problem Addressed</h2>
        <p>{capstone.problem}</p>
      </section>
      <section>
        <h2>Discussion of the Features</h2>
        <ul class="plain-list feature-checklist">
          {capstone.features.map((feature) => <li>{feature}</li>)}
        </ul>
      </section>
    </div>
  </article>

  <section class="section section-muted">
    <div class="container">
      <SectionHeading
        eyebrow="Screenshots of the GUI"
        title="System interface"
        intro="Full interface screenshots from the PlanterAid dashboard and notification workflow."
      />
      <ScreenshotGallery images={guiImages} label="PlanterAid GUI screenshots" />
    </div>
  </section>

  <section class="section">
    <div class="container technology-layout">
      <section>
        <h2>Software Used</h2>
        <ul class="tag-list large">
          {capstone.software.map((item) => <li>{item}</li>)}
        </ul>
      </section>
      <section>
        <h2>Hardware Used</h2>
        <ul class="plain-list">
          {capstone.hardware.map((item) => <li>{item}</li>)}
        </ul>
        <p class="note">The enclosure is described as weather-resistant, not waterproof.</p>
      </section>
    </div>
  </section>

  <section class="section section-muted">
    <div class="container">
      <SectionHeading
        eyebrow="Prototype Hardware"
        title="Sensor-node and field placement"
      />
      <ScreenshotGallery images={hardwareImages} label="PlanterAid hardware images" />
    </div>
  </section>

  <section class="section">
    <div class="container">
      <SectionHeading
        eyebrow="Testing"
        title="Validation and continuous-operation setup"
      />
      <ScreenshotGallery images={testingImages} label="PlanterAid testing images" />
      <div class="report-content testing-copy">
        <section><h2>Methodology</h2><p>{capstone.methodology}</p></section>
        <section><h2>My Contribution</h2><p>{capstone.contribution}</p></section>
        <section><h2>Project Outcome</h2><p>{capstone.outcome}</p></section>
      </div>
    </div>
  </section>
</BaseLayout>
