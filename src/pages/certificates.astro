---
import BaseLayout from "../layouts/BaseLayout.astro";
import PageHeader from "../components/PageHeader.astro";
import CertificateCard from "../components/CertificateCard.astro";
import { credentials } from "../data/certificates";

const certificateItems = credentials.filter((item) => item.category === "Certificate" || item.category === "Training");
---

<BaseLayout
  title="Certificates and Training | Vincent Harry H. Trayvilla"
  description="Verified certificates and training records from the current CV of Vincent Harry H. Trayvilla."
  path="/certificates/"
>
  <PageHeader
    eyebrow="Credentials"
    title="Certificates and Training"
    intro="Credential titles and dates are taken from my current CV. A visual preview is shown only for the certificate file that is available and verified as mine."
  />

  <section class="section">
    <div class="container">
      <div class="credential-grid">
        {certificateItems.map((credential) => <CertificateCard credential={credential} />)}
      </div>
    </div>
  </section>
</BaseLayout>
