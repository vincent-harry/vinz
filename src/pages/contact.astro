---
import BaseLayout from "../layouts/BaseLayout.astro";
import PageHeader from "../components/PageHeader.astro";
import { profile } from "../data/profile";
---

<BaseLayout
  title="Contact | Vincent Harry H. Trayvilla"
  description="Professional contact information for Vincent Harry H. Trayvilla."
  path="/contact/"
>
  <PageHeader
    eyebrow="Contact"
    title="Professional Contact Information"
    intro="For academic, project, practicum, or entry-level IT opportunities."
  />

  <section class="section contact-section contact-page-section">
    <div class="container contact-layout">
      <div class="contact-intro">
        <h2>Get in touch</h2>
        <p>Email is the most direct way to contact me regarding projects and professional opportunities.</p>
        <a class="btn btn-secondary" href={`mailto:${profile.email}`}>Email Vincent</a>
      </div>

      <address class="contact-list">
        <a href={`mailto:${profile.email}`}><span>Email</span><strong>{profile.email}</strong></a>
        <a href={`tel:${profile.phone.replace(/\s/g, "")}`}><span>Mobile</span><strong>{profile.phone}</strong></a>
        <a
          href={profile.linkedin}
          target="_blank"
          rel="noopener noreferrer"
          aria-label="Open Vincent Trayvilla's LinkedIn profile in a new tab"
        ><span>LinkedIn</span><strong>vincent-harry-trayvilla</strong></a>
        <a
          href={profile.github}
          target="_blank"
          rel="noopener noreferrer"
          aria-label="Open Vincent Trayvilla's GitHub profile in a new tab"
        ><span>GitHub</span><strong>vincent-harry</strong></a>
        <div><span>Location</span><strong>{profile.location}</strong></div>
      </address>
    </div>
  </section>
</BaseLayout>
