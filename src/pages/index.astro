---
import BaseLayout from "../layouts/BaseLayout.astro";
import SectionHeading from "../components/SectionHeading.astro";
import CvSection from "../components/CvSection.astro";
import SkillGroup from "../components/SkillGroup.astro";
import CertificateCard from "../components/CertificateCard.astro";
import ProjectCard from "../components/ProjectCard.astro";
import CapstoneSection from "../components/CapstoneSection.astro";
import PracticumSection from "../components/PracticumSection.astro";
import DocumentCard from "../components/DocumentCard.astro";
import { profile } from "../data/profile";
import { skillGroups } from "../data/skills";
import { credentials } from "../data/certificates";
import { academicProjects } from "../data/projects";
import { appendices } from "../data/appendices";

const certificateItems = credentials.filter((item) => item.category === "Certificate");
const seminarItems = credentials.filter(
  (item) => item.category === "Seminar" || item.category === "Training",
);
---

<BaseLayout
  title="Vincent Harry H. Trayvilla | IT Portfolio"
  description="Single-page academic IT portfolio of Vincent Harry H. Trayvilla featuring his curriculum vitae, skills, credentials, software projects, PlanterAid Capstone project, and practicum final report."
  path="/"
>
  <section class="hero" id="home" aria-labelledby="home-heading">
    <div class="container hero-layout">
      <div class="hero-intro">
        <h1 id="home-heading">{profile.name}</h1>
        <p class="hero-title">{profile.title}</p>
      </div>

      <figure class="portrait-panel">
        <img
          class="profile-portrait"
          src="/assets/images/profile/portfolio_pic-removebg-preview.png"
          alt="Portrait of Vincent Harry H. Trayvilla"
          width="450"
          height="450"
          decoding="async"
          fetchpriority="high"
        />
      </figure>

      <div class="hero-details">
        <p class="hero-summary">
          I develop and support practical web-based information systems, with experience in
          database work, testing, troubleshooting, documentation, and day-to-day IT support.
        </p>
        <p class="hero-school">
          {profile.program}<br />
          {profile.school} | {profile.graduation}
        </p>
        <div class="button-row">
          <a class="btn btn-pale" href="#cv">View Curriculum Vitae</a>
          <a class="btn btn-outline-light" href="#projects">View Projects</a>
          <a class="btn btn-accent" href="#practicum">View Practicum Final Report</a>
          <a
            class="btn btn-outline-light"
            href={profile.cv}
            target="_blank"
            rel="noopener noreferrer"
            download
          >
            Download CV
          </a>
        </div>
      </div>
    </div>
  </section>

  <section class="section" id="about" aria-labelledby="about-heading">
    <div class="container two-column-section">
      <SectionHeading
        id="about-heading"
        eyebrow="About Me"
        title="Development, testing, and technical support"
        intro="I am preparing for entry-level work where careful system development and dependable user support matter equally."
      />
      <div class="prose-block">
        <p>
          I am a graduating Information Technology student with hands-on experience in web-based
          information systems, database work, system testing, troubleshooting, and technical
          documentation. My academic and practicum work has involved reviewing how interfaces,
          models, controllers, and databases work together.
        </p>
        <p>
          I also have practical exposure to Windows setup, basic networking, LAN and Ethernet
          checks, hardware and software support, quality assurance, user assistance, and
          Git-based team collaboration. I approach technical work by checking details carefully,
          documenting changes clearly, and asking for review when a task affects shared systems.
        </p>
      </div>
    </div>
  </section>

  <CvSection />

  <section class="section" id="skills" aria-labelledby="skills-heading">
    <div class="container">
      <SectionHeading
        id="skills-heading"
        eyebrow="Technical Capabilities"
        title="Skills"
        intro="Technologies and support capabilities demonstrated through academic work, Capstone development, and practicum assignments."
      />
      <div class="skills-grid">
        {skillGroups.map((group) => <SkillGroup title={group.title} skills={group.skills} />)}
      </div>
    </div>
  </section>

  <section class="section section-muted" id="certificates" aria-labelledby="certificates-heading">
    <div class="container">
      <SectionHeading
        id="certificates-heading"
        eyebrow="Credentials"
        title="Certificates"
        intro="Professional and technical credentials recorded in my current curriculum vitae."
      />
      <div class="credential-grid">
        {certificateItems.map((credential) => <CertificateCard credential={credential} />)}
      </div>
    </div>
  </section>

  <section class="section" id="seminars" aria-labelledby="seminars-heading">
    <div class="container">
      <SectionHeading
        id="seminars-heading"
        eyebrow="Professional Learning"
        title="Seminars and Trainings"
        intro="Verified seminar records and training participation related to emerging technology and career readiness."
      />
      <div class="credential-grid seminar-grid">
        {seminarItems.map((credential) => <CertificateCard credential={credential} />)}
      </div>
    </div>
  </section>

  <section class="section section-muted" id="projects" aria-labelledby="projects-heading">
    <div class="container">
      <SectionHeading
        id="projects-heading"
        eyebrow="Software Developed"
        title="Academic Projects and Machine Problems"
        intro="Verified first-year, second-year, and third-year projects with feature discussions, software used, screenshots, and learning outcomes."
      />
      <div class="project-list">
        {academicProjects.map((project, index) => <ProjectCard project={project} index={index} />)}
      </div>
    </div>
  </section>

  <CapstoneSection />

  <PracticumSection />

  <section class="section section-muted" id="appendices" aria-labelledby="appendices-heading">
    <div class="container">
      <SectionHeading
        id="appendices-heading"
        eyebrow="Supporting Documents"
        title="Appendices"
        intro="Required Module 3 documents connected directly to the final portfolio submission."
      />
      <div class="document-grid">
        {appendices.map((document) => <DocumentCard document={document} />)}
      </div>
    </div>
  </section>

  <section class="section contact-section" id="contact" aria-labelledby="contact-heading">
    <div class="container contact-layout">
      <div class="contact-intro">
        <p class="eyebrow">Contact</p>
        <h2 id="contact-heading">Professional Contact Information</h2>
        <p>
          Email is the most direct way to contact me regarding academic projects, practicum work,
          and entry-level IT opportunities.
        </p>
      </div>

      <address class="contact-list">
        <a href={`mailto:${profile.email}`}><span>Email</span><strong>{profile.email}</strong></a>
        <a href={`tel:${profile.phone.replace(/\s/g, "")}`}>
          <span>Mobile</span><strong>{profile.phone}</strong>
        </a>
        <a
          href={profile.linkedin}
          target="_blank"
          rel="noopener noreferrer"
          aria-label="Open Vincent Trayvilla's LinkedIn profile in a new tab"
        >
          <span>LinkedIn</span><strong>vincent-harry-trayvilla-160644331</strong>
        </a>
        <a
          href={profile.github}
          target="_blank"
          rel="noopener noreferrer"
          aria-label="Open Vincent Trayvilla's GitHub profile in a new tab"
        >
          <span>GitHub</span><strong>vincent-harry</strong>
        </a>
        <a
          href={profile.portfolio}
          target="_blank"
          rel="noopener noreferrer"
          aria-label="Open Vincent Trayvilla's portfolio in a new tab"
        >
          <span>Portfolio</span><strong>vhhtrayvilla-portfolio.vercel.app</strong>
        </a>
        <div><span>Location</span><strong>{profile.location}</strong></div>
      </address>
    </div>
  </section>
</BaseLayout>
