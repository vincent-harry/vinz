---
import BaseLayout from "../layouts/BaseLayout.astro";
import SectionHeading from "../components/SectionHeading.astro";
import SkillGroup from "../components/SkillGroup.astro";
import { profile } from "../data/profile";
import { skillGroups } from "../data/skills";
import { academicProjects } from "../data/projects";
---

<BaseLayout
  title="Vincent Harry H. Trayvilla | IT Portfolio"
  description="Academic IT portfolio of Vincent Harry H. Trayvilla featuring his CV, programming skills, credentials, software projects, machine problems, and PlanterAid Capstone project."
  path="/"
>
  <section class="hero">
    <div class="container hero-layout">
      <div class="hero-copy">
        <p class="eyebrow">Information Technology Portfolio</p>
        <h1>{profile.name}</h1>
        <p class="hero-title">{profile.title}</p>
        <p class="hero-summary">{profile.summary}</p>
        <p class="hero-school">{profile.program}<br />{profile.school} | {profile.graduation}</p>
        <div class="button-row">
          <a class="btn btn-primary" href="/cv/">View Curriculum Vitae</a>
          <a class="btn btn-secondary" href="/projects/">View Projects</a>
          <a class="btn btn-text" href={profile.cv} download>Download CV</a>
        </div>
      </div>
      <aside class="profile-panel" aria-label="Professional profile summary">
        <div class="profile-initials" aria-hidden="true">VT</div>
        <dl>
          <div><dt>Program</dt><dd>BS Information Technology</dd></div>
          <div><dt>Focus</dt><dd>Web systems and IT support</dd></div>
          <div><dt>Location</dt><dd>{profile.location}</dd></div>
        </dl>
      </aside>
    </div>
  </section>

  <section class="section" id="about">
    <div class="container two-column-section">
      <SectionHeading
        eyebrow="About Me"
        title="Developing practical systems and supporting their users."
        intro="My academic work and practicum experience have developed my interests in web-based systems, database work, testing, documentation, troubleshooting, and day-to-day technical support."
      />
      <div class="prose-block">
        <p>
          I approach information technology as a combination of development, analysis, testing, and support. My work has included database-backed web applications, academic mobile and desktop projects, system documentation, and hardware and network troubleshooting.
        </p>
        <p>
          I am preparing for entry-level work in IT support, systems development, quality assurance, or web applications, where careful problem solving and clear communication are as important as writing code.
        </p>
      </div>
    </div>
  </section>

  <section class="section section-muted" id="skills">
    <div class="container">
      <SectionHeading
        eyebrow="Programming Skills"
        title="Verified technical skills"
        intro="Technologies and support capabilities listed in my current CV and demonstrated through academic and practicum work."
      />
      <div class="skills-grid">
        {skillGroups.map((group) => <SkillGroup title={group.title} skills={group.skills} />)}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <SectionHeading
        eyebrow="Selected Work"
        title="Software developed from first year to fourth year"
        intro="The portfolio includes verified machine-problem interfaces and a collaborative IoT Capstone project."
      />
      <div class="feature-grid">
        {academicProjects.map((project) => (
          <article class="feature-card">
            <img src={project.images[0].src} alt={project.images[0].alt} loading="lazy" />
            <div>
              <p class="project-meta">{project.year}</p>
              <h3>{project.title}</h3>
              <p>{project.overview}</p>
            </div>
          </article>
        ))}
        <article class="feature-card feature-card-capstone">
          <img src="/assets/images/capstone/multi-zone-dashboard.png" alt="PlanterAid multi-zone environmental monitoring dashboard" loading="lazy" />
          <div>
            <p class="project-meta">Fourth Year Capstone</p>
            <h3>PlanterAid</h3>
            <p>Web-based soil monitoring, recommendations, and alert notifications using IoT sensor nodes.</p>
          </div>
        </article>
      </div>
      <div class="section-actions">
        <a class="btn btn-primary" href="/projects/">Software and Machine Problems</a>
        <a class="btn btn-secondary" href="/capstone/">Capstone Project</a>
      </div>
    </div>
  </section>

  <section class="section contact-section" id="contact">
    <div class="container contact-layout">
      <SectionHeading
        eyebrow="Contact"
        title="Professional contact information"
        intro="For academic, project, or entry-level IT opportunities."
      />
      <address class="contact-list">
        <a href={`mailto:${profile.email}`}><span>Email</span><strong>{profile.email}</strong></a>
        <a href={`tel:${profile.phone.replace(/\s/g, "")}`}><span>Mobile</span><strong>{profile.phone}</strong></a>
        <a href={profile.linkedin} target="_blank" rel="noopener noreferrer"><span>LinkedIn</span><strong>vincent-harry-trayvilla</strong></a>
        <a href={profile.github} target="_blank" rel="noopener noreferrer"><span>GitHub</span><strong>vincent-harry</strong></a>
        <div><span>Location</span><strong>{profile.location}</strong></div>
      </address>
    </div>
  </section>
</BaseLayout>
