---
import BaseLayout from "../layouts/BaseLayout.astro";
import PageHeader from "../components/PageHeader.astro";
import { practicum } from "../data/practicum";
---

<BaseLayout
  title="Practicum Final Report | Vincent Harry H. Trayvilla"
  description="Final practicum report covering Vincent Harry H. Trayvilla's engagement with the City Government of Biñan."
  path="/practicum/"
>
  <PageHeader
    eyebrow="Practicum Final Report"
    title="M3Activity1: Final Report and Portfolio"
    intro="Submission of Final Report and Portfolio for Practicum"
  />

  <article class="section practicum-report">
    <div class="container reading-width">
      <dl class="report-facts">
        <div><dt>Host Organization</dt><dd>{practicum.host}</dd></div>
        <div><dt>Assigned Project</dt><dd>{practicum.project}</dd></div>
        <div><dt>Role</dt><dd>{practicum.role}</dd></div>
        <div><dt>Period</dt><dd>{practicum.period}</dd></div>
      </dl>

      <div class="practicum-report-sections">
        {practicum.sections.map((section, index) => (
          <section class="report-panel">
            <p class="report-number">{String(index + 1).padStart(2, "0")}</p>
            <div>
              <h2>{section.title}</h2>
              <p>{section.content}</p>
            </div>
          </section>
        ))}
      </div>
    </div>
  </article>
</BaseLayout>
