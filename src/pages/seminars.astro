---
import BaseLayout from "../layouts/BaseLayout.astro";
import PageHeader from "../components/PageHeader.astro";
import CertificateCard from "../components/CertificateCard.astro";
import { credentials } from "../data/certificates";

const seminarItems = credentials.filter((item) => item.category === "Seminar");
---

<BaseLayout
  title="Seminars | Vincent Harry H. Trayvilla"
  description="Seminars and emerging-technology sessions completed by Vincent Harry H. Trayvilla."
  path="/seminars/"
>
  <PageHeader
    eyebrow="Seminars"
    title="Seminars and Emerging-Technology Sessions"
    intro="Seminar records verified from my current curriculum vitae."
  />

  <section class="section section-muted">
    <div class="container">
      <div class="credential-grid seminar-grid">
        {seminarItems.map((credential) => <CertificateCard credential={credential} />)}
      </div>
    </div>
  </section>
</BaseLayout>
