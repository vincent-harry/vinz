---
import BaseLayout from "../layouts/BaseLayout.astro";
import PageHeader from "../components/PageHeader.astro";
import SkillGroup from "../components/SkillGroup.astro";
import { skillGroups } from "../data/skills";
---

<BaseLayout
  title="Programming Skills | Vincent Harry H. Trayvilla"
  description="Programming, database, development-tool, IT support, and networking skills of Vincent Harry H. Trayvilla."
  path="/skills/"
>
  <PageHeader
    eyebrow="Programming Skills"
    title="Technical Skills and Expertise"
    intro="Technologies and support capabilities verified from my current CV and demonstrated through academic and practicum work."
  />

  <section class="section section-muted">
    <div class="container">
      <h2 class="sr-only">Skills by category</h2>
      <div class="skills-grid">
        {skillGroups.map((group) => <SkillGroup title={group.title} skills={group.skills} />)}
      </div>
    </div>
  </section>
</BaseLayout>
